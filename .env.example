# nizan: model configuration
# copy this file to .env and fill in your values:
#   cp .env.example .env

# pick your model (litellm format)
MODEL=anthropic/claude-sonnet-4-20250514

# provider API key
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# for a locally run llm like: ollama, as it needs no key: just set for example MODEL=ollama/llama3
